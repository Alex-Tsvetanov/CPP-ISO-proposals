index ffce0a146..62e54c51b 100644
--- a/clang/lib/Sema/SemaDeclCXX.cpp
+++ b/clang/lib/Sema/SemaDeclCXX.cpp
@@ -3265,6 +3265,66 @@ bool Sema::ActOnAccessSpecifier(AccessSpecifier Access, SourceLocation ASLoc,
   return ProcessAccessDeclAttributeList(ASDecl, Attrs);
 }
 
+void Sema::ActOnDeducedAutoOverrideReturnType(CXXMethodDecl *MD) {
+  // Feature is C++26-only; older standards keep today's behaviour (the bare
+  // `auto`/`override` combination is diagnosed by CheckOverridingFunctionReturnType).
+  if (!getLangOpts().CPlusPlus26 || !MD || MD->isInvalidDecl())
+    return;
+  const auto *FPT = MD->getType()->getAs<FunctionProtoType>();
+  if (!FPT)
+    return;
+  const AutoType *AT = FPT->getReturnType()->getAs<AutoType>();
+  if (!AT || !AT->isUndeducedAutoType())
+    return; // not a placeholder return type
+
+  // Only an overriding function adopts a return type from a base.
+  if (MD->size_overridden_methods() == 0)
+    return; // ordinary (non-virtual) deduced-return function: leave untouched
+
+  bool IsBareAuto =
+      AT->getKeyword() == AutoTypeKeyword::Auto && !AT->isConstrained();
+
+  // The feature is triggered only by the bare `auto` placeholder written with the
+  // `override` virt-specifier (which is already on MD at this point).
+  if (IsBareAuto && MD->hasAttr<OverrideAttr>()) {
+    QualType T, Other;
+    for (const CXXMethodDecl *Base : MD->overridden_methods()) {
+      QualType BT = Base->getReturnType();
+      if (T.isNull())
+        T = BT;
+      else if (!Context.hasSameType(T, BT)) {
+        Other = BT;
+        break;
+      }
+    }
+    if (!Other.isNull()) {
+      // Multiple inheritance: the overridden functions disagree on the return
+      // type, so there is no single type to adopt.
+      Diag(MD->getLocation(), diag::err_auto_override_ambiguous_return)
+          << MD->getDeclName() << T << Other;
+      MD->setInvalidDecl();
+      return;
+    }
+    if (T.isNull() || T->isUndeducedType() || T->isDependentType())
+      return; // overridden type not yet known (e.g. dependent base): leave to deduction
+
+    // Fix the return type to the overridden function's, exactly as if written out.
+    // Override checking and vtable layout then proceed as for any ordinary member.
+    MD->setType(
+        Context.getFunctionType(T, FPT->getParamTypes(), FPT->getExtProtoInfo()));
+    // Remember it so each `return` statement is checked against T with no implicit
+    // conversion (BuildReturnStmt).
+    DeducedVirtualOverrideReturns.insert(MD->getCanonicalDecl());
+    return;
+  }
+
+  // A virtual (overriding) function whose placeholder return type the feature does
+  // not cover: bare `auto` without `override`, or `decltype(auto)` / a constrained
+  // placeholder. The existing prohibition on a virtual deduced return type stands.
+  Diag(MD->getLocation(), diag::err_auto_fn_virtual);
+  MD->setInvalidDecl();
+}
