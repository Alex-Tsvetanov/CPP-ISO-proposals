\title{Deduced return type for overriding functions via
\VERB|\KeywordTok{auto}|}
\author{&Alex
Tsvetanov\\&<\href{mailto:alex_tsvetanov_2002@abv.bg}{\nolinkurl{alex\_tsvetanov\_2002@abv.bg}}>\\}
\date{2026-06-25}

\begin{document}
\hypertarget{title-block-header}{\label{title-block-header}}
\maketitle

{
\hypersetup{linkcolor=black}
